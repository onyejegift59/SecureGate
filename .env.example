# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/securegate

# Used by NextAuth to encrypt JWTs and cookies (minimum 32 characters)
NEXTAUTH_SECRET=your-secret-here-at-least-32-characters-long

# Canonical URL of your site (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Gmail SMTP credentials for transactional emails.
# EMAIL_USER must be a Gmail address.
# EMAIL_PASS must be a Gmail App Password (not your regular password).
# See: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Upstash Redis REST URL for rate limiting
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io

# Upstash Redis REST token for rate limiting
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxx
